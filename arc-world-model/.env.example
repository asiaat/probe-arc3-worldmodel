# ARC-AGI-3 API key (get from https://arcprize.org)
ARC_API_KEY=your-api-key-here

# Data collection settings
TRAIN_GAMES=ls20,ft09
EVAL_GAMES=ft09
COLLECTION_TARGET_TRANSITIONS=10000
COLLECTION_MAX_STEPS_PER_EPISODE=500

# Paths
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs

# Training
DEVICE=cuda
SEED=42

# Optional — only if using wandb
WANDB_PROJECT=arcwm
WANDB_ENTITY=
